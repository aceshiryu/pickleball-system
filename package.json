  "scripts": {
    "create-env:api": "printenv > apps/api/dist/.env",
    "create-env:web": "printenv > apps/web/dist/.env",
    "create-env:admin": "printenv > apps/admin/dist/.env",
    "dev": "nx run-many -t serve,dev,start --projects=api,web",
    "build": "nx run-many -t build --projects=api,web,admin",
    "lint": "nx run-many -t lint --projects=api,web,admin",
    "test": "nx run-many -t test --projects=api,web",
    "test:api": "nx test api",
    "test:web": "nx test web",
    "e2e": "nx run-many -t e2e --projects=api-e2e,web-e2e",
    "e2e:api": "nx e2e api-e2e",
    "e2e:web": "nx e2e web-e2e",
    "dev:api": "nx serve api",
    "dev:web": "nx dev web",
    "dev:admin": "nx dev admin",
    "build:api": "nx build api",
    "build:web": "NODE_ENV=production nx build web",
    "build:admin": "NODE_ENV=production nx build admin",
    "lint:api": "nx lint api",
    "lint:web": "nx lint web",
    "lint:admin": "nx lint admin",
    "migration-create:api": "npx nx run api:migration-create",
    "migration-generate:api": "npx nx run api:migration-generate",
    "migration-win": "npx nx run api:migration-run-win",
    "migration": "npx nx run api:migration-run",
    "seed-create": "npx nx run api:seed-create",
    "seed-win": "npx nx run api:seed-run-win",
    "seed": "npx nx run api:seed-run",
    "update-sources-windows": "curl http://localhost:3001/api-docs-json > api-docs.json && npx openapi-generator-cli generate -i api-docs.json -g typescript-axios -o libs/api-lib/src --skip-validate-spec",
    "update-sources": "curl http://localhost:3001/api-docs-json > api-docs.json && npx openapi-generator-cli generate -i api-docs.json -g typescript-axios -o libs/api-lib/src --skip-validate-spec"
  },
