NEXT_PUBLIC_API_BASE_URL=http://localhost:3001/api

# Hostname split for the deployed demo (see src/middleware.ts and dispatch.yaml).
# The customer app and the admin console are one Next.js deployable served on two
# hostnames: the admin host redirects / to /admin and serves nothing else, and the
# customer host refuses /admin. Leave BOTH blank locally — an unrecognised host
# falls through and every route behaves normally on localhost.
NEXT_PUBLIC_ADMIN_HOST=
NEXT_PUBLIC_CUSTOMER_HOST=

# Google sign-in. Must be the SAME OAuth 2.0 Web application client ID the API
# has in GOOGLE_CLIENT_ID — the API rejects tokens minted for any other client.
# Safe to ship to the browser (it is not a secret); the client *secret* is not
# used by this flow and must never appear in a NEXT_PUBLIC_ var.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
