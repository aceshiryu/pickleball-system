NODE_ENV=development
PORT=3001

# Postgres
# Use 127.0.0.1 (not localhost) — on macOS localhost resolves to IPv6 ::1 first and
# can hang the pg connection if Postgres only listens on IPv4 (e.g. Postgres.app).
DB_HOST=127.0.0.1
DB_PORT=5433
# Local dev defaults to the macOS user with trust auth (Postgres.app has no `postgres`
# role by default). Change these if your local Postgres uses a different role/password.
# Deployed envs override DB_USERNAME/DB_PASSWORD via Secret Manager.
DB_USERNAME=acecerio
DB_PASSWORD=

# Deployed envs point at a shared Supabase project, where the database is
# ALWAYS called `postgres` — so DB_NAME is not a secret and is set as a plain
# cloudbuild substitution, not via Secret Manager. Only the credentials are
# secret. Locally this is a dedicated database, so the name is whatever you made.
DB_NAME=pickleball_dev

# Which schema this deployment owns. Several projects share one Supabase
# project, so the schema — not the database name — is what keeps them apart.
# Blank/unset means `public`, which is what you want locally.
# The schema must already exist; TypeORM will not create it:
#   CREATE SCHEMA IF NOT EXISTS pickleball;
DB_SCHEMA=

DB_SYNCHRONIZE=false
DB_LOGGING=true

# TLS for managed Postgres (Supabase, Cloud SQL public IP). Deployed envs set
# _DB_SSL=true in cloudbuild. Leave false for a local trust-auth Postgres.
DB_SSL=false

# --- E2E test databases -------------------------------------------------
# Two SEPARATE databases, one per suite, so `nx run-many -t e2e` can run both
# at once without one truncating the other's data mid-run. Both are created
# automatically on first run and are wiped every run — never point either at a
# database you care about.
#
# The suites refuse to start unless the name matches /e2e|test/i, which is the
# guard that stops a stray DB_NAME from truncating your dev data.
#
# They reuse DB_HOST / DB_PORT / DB_USERNAME / DB_PASSWORD above; only the
# database name differs.

# API suite (apps/api-e2e — jest + supertest, no browser)
E2E_DB_NAME=pickleball_e2e

# Browser suite (apps/web-e2e — playwright, drives the real web app)
WEB_E2E_DB_NAME=pickleball_web_e2e

# Auth
JWT_SECRET=replace-me-with-a-long-random-string
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=10

# Google sign-in (customers only; admin/staff use email + password).
# This is the OAuth 2.0 *Web application* client ID from Google Cloud Console —
# the same value as the web app's NEXT_PUBLIC_GOOGLE_CLIENT_ID. It is not a
# secret, but it must match, because the API verifies that incoming ID tokens
# were minted for exactly this client. No client secret is needed: the browser
# uses the implicit ID-token flow, not an authorization-code exchange.
# Leave blank and customer sign-in returns 503 rather than letting anyone in.
GOOGLE_CLIENT_ID=

# Supabase Storage (images: receipts, brand logo, payment QRs)
# Leave blank locally to keep storage disabled — the app still runs, it just
# won't persist images. The service-role key is server-side only, never shipped
# to the browser.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Private bucket (signed URLs) for payment receipts
SUPABASE_RECEIPTS_BUCKET=receipts
# Public bucket for brand assets the landing/login pages read pre-auth
SUPABASE_PUBLIC_BUCKET=brand

# CORS (comma-separated)
CORS_ORIGINS=http://localhost:3000

# Rate limit
THROTTLE_TTL=60
THROTTLE_LIMIT=100
