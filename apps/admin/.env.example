NEXT_PUBLIC_API_BASE_URL=http://localhost:3001/api

# Web key for the calendar-read endpoints the console also uses (courts,
# overrides, settings). Must be the SAME value as the API's WEB_PUBLIC_API_KEY,
# or requests 401. Inlined at BUILD time — changing it needs a rebuild. Blank =
# no key sent (fine only if the API's gate is also off).
#
# The admin app signs staff in with email + password, so it needs NO Google
# client id — that's why there's no NEXT_PUBLIC_GOOGLE_CLIENT_ID here.
NEXT_PUBLIC_WEB_KEY=
