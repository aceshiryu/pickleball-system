NEXT_PUBLIC_API_BASE_URL=http://localhost:3001/api

# Google sign-in. Must be the SAME OAuth 2.0 Web application client ID the API
# has in GOOGLE_CLIENT_ID — the API rejects tokens minted for any other client.
# Safe to ship to the browser (it is not a secret); the client *secret* is not
# used by this flow and must never appear in a NEXT_PUBLIC_ var.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Web key for the guest + calendar-read endpoints (PublicKeyGuard on the API).
# Must be the SAME value as the API's WEB_PUBLIC_API_KEY, or every request 401s.
# Inlined into the bundle at BUILD time — changing it needs a rebuild, not just
# an env edit. Blank = no key sent (fine only if the API's gate is also off).
# A bar against casual/direct access, not a secret (it's in the browser bundle).
NEXT_PUBLIC_WEB_KEY=
